<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#f5ede3">
  <title>
    {{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {% if settings.favicon != blank %}
    <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" type="image/png">
  {% endif %}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <link rel="stylesheet" href="{{ 'style.css' | asset_url }}">
</head>

<body class="template-{{ template.name }}{% if customer %} customer-logged-in{% endif %}">
  <div class="grain-overlay"></div>
  <div class="cursor-dot" id="CursorDot"></div>
  <div class="cursor-outline" id="CursorOutline"></div>
  <div class="scroll-progress-container">
    <div class="scroll-progress-bar" id="ScrollProgress"></div>
  </div>
  <div class="page-transition-overlay" id="PageTransition"></div>

  <a href="#MainContent" class="skip-to-content">Skip to content</a>

  <!-- Announcement Bar (Rotatable) -->
  <div class="announcement-bar" id="AnnouncementBar">
    <div class="announcement-bar__inner">
      <div class="announcement-message active">✨ Free shipping on orders above ₹999</div>
      <div class="announcement-message">🌸 New arrivals every Friday — Shop Now</div>
      <div class="announcement-message">💛 Handwoven. Handpicked. Heartfelt.</div>
      <div class="announcement-message">💳 10% Off on your first order! Use: WELCOME10</div>
    </div>
  </div>

  {% section 'header' %}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Cart Drawer -->
  <div class="cart-drawer" id="CartDrawer" aria-hidden="true">
    <div class="cart-drawer__overlay" onclick="closeCart()"></div>
    <div class="cart-drawer__inner">
      <div class="cart-drawer__header">
        <div class="cart-drawer__header-top">
          <h3>Your Cart</h3>
          <button class="cart-drawer__close" onclick="closeCart()" aria-label="Close cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
        
        <div class="free-shipping-bar" id="FreeShippingBar">
          <p class="free-shipping-bar__message"></p>
          <div class="free-shipping-bar__progress">
            <div class="free-shipping-bar__fill"></div>
          </div>
        </div>
      </div>
      <div class="cart-drawer__body" id="CartDrawerBody">
        {% if cart.item_count == 0 %}
          <div class="cart-empty">
            <div class="cart-empty__icon">🛍️</div>
            <p>Your cart is empty</p>
            <a href="/collections/all" class="btn btn--primary" onclick="closeCart()">Start Shopping</a>
          </div>
        {% else %}
          {% for item in cart.items %}
            <div class="cart-item" data-key="{{ item.key }}">
              <div class="cart-item__image">
                <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title }}" loading="lazy">
              </div>
              <div class="cart-item__details">
                <h4>{{ item.product.title }}</h4>
                {% unless item.variant.title == 'Default Title' %}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {% endunless %}
                <div class="cart-item__price-qty">
                  <span class="cart-item__price">{{ item.final_price | money }}</span>
                  <div class="cart-item__qty">
                    <button onclick="updateCart('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
                    <span>{{ item.quantity }}</span>
                    <button onclick="updateCart('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
                  </div>
                </div>
              </div>
              <button class="cart-item__remove" onclick="updateCart('{{ item.key }}', 0)" aria-label="Remove">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 6L6 18M6 6l12 12"/>
                </svg>
              </button>
            </div>
          {% endfor %}
        {% endif %}
      </div>
      {% if cart.item_count > 0 %}
        <div class="cart-drawer__footer">
          <div class="cart-total">
            <span>Total</span>
            <span class="cart-total__price">{{ cart.total_price | money }}</span>
          </div>
          <a href="/checkout" class="btn btn--primary btn--full">Proceed to Checkout</a>
          <a href="/cart" class="btn btn--secondary btn--full">View Full Cart</a>
        </div>
      {% endif %}
    </div>
  </div>

  <!-- Exit Intent Popup -->
  <div id="ExitIntentPopup" class="modal-overlay" style="display: none;">
    <div class="modal-content exit-popup">
      <button class="modal-close" onclick="closeExitPopup()">&times;</button>
      <div class="exit-popup__inner">
        <span class="exit-popup__tag">Exclusive Offer</span>
        <h2>Wait! Your 10% Discount is Waiting</h2>
        <p>Join 50,000+ elegant women who receive our exclusive heritage collection updates and special offers.</p>
        <div class="exit-popup__countdown" id="ExitCountdown">Offer expires in <span id="QVTimer">05:00</span></div>
        <form class="exit-popup__form" onsubmit="event.preventDefault(); showToast('Welcome! Your code VASTHRA10 has been activated.')">
          <input type="email" placeholder="Your best email address" required>
          <button type="submit" class="btn btn--primary btn--full">Claim My 10% Off</button>
        </form>
        <p class="exit-popup__fineprint" onclick="closeExitPopup()">No thanks, I'll pay full price.</p>
      </div>
    </div>
  </div>

  {% render 'recent-sales' %}
  {% render 'quick-view' %}

  <!-- Lightbox Modal -->
  <div id="LightboxModal" class="lightbox-modal" onclick="closeLightbox()">
    <button class="lightbox-close" onclick="closeLightbox()">&times;</button>
    <img id="LightboxImg" class="lightbox-modal__img" src="" alt="Zoomed product image">
  </div>

  <style>
    /* Free Shipping Bar */
    .free-shipping-bar { padding: 15px 20px; background: #fafafa; border-bottom: 1px solid #eee; }
    .free-shipping-bar__message { font-size: 0.75rem; margin-bottom: 8px; font-weight: 500; text-align: center; }
    .free-shipping-bar__progress { height: 6px; background: #eee; border-radius: 10px; overflow: hidden; }
    .free-shipping-bar__fill { height: 100%; background: var(--clr-maroon); width: 0; transition: width 0.5s ease; }
    
    /* Announcement Bar Rotation */
    .announcement-bar { overflow: hidden; position: relative; height: 40px; }
    .announcement-bar__inner { position: relative; height: 100%; }
    .announcement-message {
      position: absolute; width: 100%; height: 100%;
      display: none; align-items: center; justify-content: center;
      text-align: center; font-size: 0.85rem; letter-spacing: 0.05em;
    }
    .announcement-message.active { display: flex; animation: fadeInDown 0.4s ease; }
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Exit Popup */
    .exit-popup { max-width: 450px; text-align: center; padding: 40px 30px; }
    .exit-popup__tag { color: var(--clr-maroon); font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; }
    .exit-popup h2 { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; margin: 15px 0; }
    .exit-popup p { font-size: 0.95rem; color: #666; margin-bottom: 25px; line-height: 1.5; }
    .exit-popup__form { display: flex; flex-direction: column; gap: 12px; }
    .exit-popup__form input { padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; }
    .exit-popup__fineprint { margin-top: 15px !important; font-size: 0.75rem !important; cursor: pointer; text-decoration: underline; }
  </style>

  <!-- Floating WhatsApp Button -->
  <a href="https://wa.me/919876543210?text=Hello!%20I%20need%20help%20with%20a%20saree%20order." class="floating-wa" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Cookie Consent -->
  <div id="CookieConsent" class="cookie-banner" style="display: none;">
    <p>We use cookies to improve your experience and for analytics. By continuing to use our site, you accept our use of cookies and our Privacy Policy.</p>
    <div class="cookie-btns">
      <button class="btn btn--primary" onclick="acceptCookies()">Accept</button>
      <button class="btn btn--ghost" onclick="document.getElementById('CookieConsent').style.display='none'">Decline</button>
    </div>
  </div>

  <!-- Back to Top Button -->
  <button id="BackToTop" class="back-to-top" aria-label="Back to top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
  </button>

  {% render 'mobile-nav' %}

  <script src="{{ 'script.js' | asset_url }}" defer></script>
</body>
</html>
