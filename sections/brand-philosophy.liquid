{% schema %}
{
  "name": "Brand Philosophy",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted to Define You"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Philosophy Text",
      "default": "At Frillve, we believe every piece of clothing should tell a story of whimsical luxury and timeless grace. Our couture collections for children and women are meticulously crafted to celebrate the magic in every moment."
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Brand Philosophy"
    }
  ]
}
{% endschema %}

<section class="brand-philosophy" id="BrandPhilosophy">
  <div class="philosophy-container">
    <div class="philosophy-content" data-animate>
      <span class="philosophy-eyebrow">The Frillve Promise</span>
      <h2 class="philosophy-heading">{{ section.settings.heading }}</h2>
      <div class="philosophy-divider">
        <svg width="60" height="20" viewBox="0 0 60 20" fill="none">
          <path d="M0 10C15 10 15 2 30 2C45 2 45 10 60 10" stroke="var(--clr-gold)" stroke-width="1"/>
        </svg>
      </div>
      <p class="philosophy-text">{{ section.settings.text }}</p>
      <div class="philosophy-signature">Frillve Boutique</div>
    </div>
  </div>
</section>

<style>
.brand-philosophy {
  padding: 120px 0;
  background-color: var(--clr-emerald, #064e3b);
  background-image: 
    radial-gradient(circle at 10% 10%, rgba(212, 175, 55, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 90% 90%, rgba(212, 175, 55, 0.05) 0%, transparent 50%);
  color: var(--clr-white);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.philosophy-container {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 24px;
}

.philosophy-eyebrow {
  display: block;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 4px;
  color: var(--clr-gold);
  margin-bottom: 24px;
}

.philosophy-heading {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 300;
  margin-bottom: 30px;
  line-height: 1.2;
}

.philosophy-divider {
  margin-bottom: 30px;
}

.philosophy-text {
  font-size: 1.15rem;
  line-height: 1.8;
  opacity: 0.9;
  max-width: 650px;
  margin: 0 auto 40px;
  font-style: italic;
}

.philosophy-signature {
  font-family: var(--font-display);
  font-size: 1.5rem;
  color: var(--clr-gold);
}

@media (max-width: 768px) {
  .brand-philosophy { padding: 80px 0; }
  .philosophy-text { font-size: 1rem; }
}
</style>
