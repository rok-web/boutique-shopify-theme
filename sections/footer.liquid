{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Brand name",
      "default": "Vasthralaya"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Handwoven stories, draped in tradition. Every thread carries the legacy of India's finest weavers."
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "text",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp number (with country code)",
      "default": "919876543210"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "hello@vasthralaya.com"
    },
    {
      "type": "link_list",
      "id": "quick_links",
      "label": "Quick links menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "policy_links",
      "label": "Policy links menu"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2025 Vasthralaya. All rights reserved."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}

<footer class="site-footer">

  <!-- Trust badges strip -->
  <div class="footer-trust-strip">
    <div class="container">
      <div class="trust-badges">
        <div class="trust-badge" data-animate>
          <div class="trust-badge__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 11l4 4L19 7"/></svg>
          </div>
          <div class="trust-badge__text">
            <strong>Authentic Heritage</strong>
            <span>100% genuine handloom</span>
          </div>
        </div>
        <div class="trust-badge" data-animate data-animate-delay="100">
          <div class="trust-badge__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <div class="trust-badge__text">
            <strong>7-Day Returns</strong>
            <span>Hassle-free exchanges</span>
          </div>
        </div>
        <div class="trust-badge" data-animate data-animate-delay="200">
          <div class="trust-badge__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <div class="trust-badge__text">
            <strong>Free Shipping</strong>
            <span>On orders above ₹999</span>
          </div>
        </div>
        <div class="trust-badge" data-animate data-animate-delay="300">
          <div class="trust-badge__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="trust-badge__text">
            <strong>Secure Checkout</strong>
            <span>PCI DSS compliant</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main footer -->
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">

        <!-- Brand column -->
        <div class="footer-col footer-col--brand">
          <a href="/" class="footer-logo">{{ section.settings.logo_text }}</a>
          {% if section.settings.tagline %}
            <p class="footer-tagline">{{ section.settings.tagline }}</p>
          {% endif %}

          <!-- Social links -->
          <div class="footer-social">
            {% if section.settings.instagram_url != blank %}
              <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" class="social-link" aria-label="Instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {% endif %}
            {% if section.settings.facebook_url != blank %}
              <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" class="social-link" aria-label="Facebook">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </a>
            {% endif %}
            {% if section.settings.whatsapp_number != blank %}
              <a href="https://wa.me/{{ section.settings.whatsapp_number }}" target="_blank" rel="noopener" class="social-link" aria-label="WhatsApp">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
              </a>
            {% endif %}
          </div>

          <!-- WhatsApp CTA -->
          {% if section.settings.whatsapp_number != blank %}
            <a href="https://wa.me/{{ section.settings.whatsapp_number }}?text=Hi! I'd like to know more about your sarees." class="whatsapp-cta" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Chat on WhatsApp
            </a>
          {% endif %}
        </div>

        <!-- Quick Links -->
        <div class="footer-col">
          <h4 class="footer-col__title">Quick Links</h4>
          <ul class="footer-links">
            {% for link in linklists[section.settings.quick_links].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>

        <!-- Categories -->
        <div class="footer-col">
          <h4 class="footer-col__title">Categories</h4>
          <ul class="footer-links">
            <li><a href="/collections/sarees">Sarees</a></li>
            <li><a href="/collections/suits">Suits & Salwar Kameez</a></li>
            <li><a href="/collections/lehenga">Lehengas</a></li>
            <li><a href="/collections/kurtis">Kurtis & Tops</a></li>
            <li><a href="/collections/dupattas">Dupattas</a></li>
            <li><a href="/collections/new-arrivals">New Arrivals</a></li>
          </ul>
        </div>

        <!-- Help & Contact -->
        <div class="footer-col">
          <h4 class="footer-col__title">Help & Support</h4>
          <ul class="footer-links">
            {% for link in linklists[section.settings.policy_links].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/size-guide">Size Guide</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          </ul>
          {% if section.settings.email != blank %}
            <a href="mailto:{{ section.settings.email }}" class="footer-email">{{ section.settings.email }}</a>
          {% endif %}
        </div>

      </div>
    </div>
  </div>

  <!-- Footer bottom bar -->
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom__inner">
        <p class="footer-copyright">{{ section.settings.copyright }}</p>
        <div class="footer-secure-badges">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>SSL Secured Checkout</span>
        </div>
        <div class="payment-icons">
          <span class="payment-icon">UPI</span>
          <span class="payment-icon">Visa</span>
          <span class="payment-icon">Mastercard</span>
          <span class="payment-icon">RuPay</span>
          <span class="payment-icon">COD</span>
        </div>
      </div>
    </div>
  </div>

</footer>
