{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (if no image)",
      "default": "Vasthralaya"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}

<header class="site-header" id="SiteHeader">
  <div class="header-inner">

    <!-- Hamburger (mobile) -->
    <button class="hamburger" id="HamburgerBtn" aria-label="Open menu" onclick="toggleMobileMenu()">
      <span></span><span></span><span></span>
    </button>

    <!-- Logo -->
    <a href="/" class="header-logo">
      {% if section.settings.logo %}
        <img src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
             alt="{{ shop.name }}"
             width="{{ section.settings.logo_width }}"
             loading="eager">
      {% else %}
        <img src="{{ 'logo.png' | asset_url }}"
             alt="Vasthralaya"
             width="{{ section.settings.logo_width }}"
             style="display: block; max-height: 50px; width: auto;"
             loading="eager">
      {% endif %}
    </a>

    <nav class="header-nav" id="HeaderNav">
      {% for link in linklists[section.settings.main_menu].links %}
        {% if link.links != blank %}
          {% assign is_mega = false %}
          {% if link.title == 'Shop' or link.title == 'Collections' %}
            {% assign is_mega = true %}
          {% endif %}
          
          <div class="nav-item has-dropdown {% if is_mega %}has-mega-menu{% endif %}">
            <a href="{{ link.url }}" class="nav-link">
              {{ link.title }}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            
            {% if is_mega %}
              <div class="nav-dropdown nav-dropdown--mega">
                <div class="mega-menu__container">
                  {% for child_link in link.links %}
                    <div class="mega-menu__col">
                      <h4 class="mega-menu__col-title">{{ child_link.title }}</h4>
                      <ul class="mega-menu__list">
                        {% for grandchild_link in child_link.links %}
                          <li><a href="{{ grandchild_link.url }}" class="mega-menu__link">{{ grandchild_link.title }}</a></li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endfor %}
                  <div class="mega-menu__col mega-menu__col--promo">
                    <div class="mega-menu__promo">
                      <img src="{{ 'category_sarees.png' | asset_url }}" alt="Handwoven Sarees" loading="lazy">
                      <div class="mega-menu__promo-content">
                        <span class="badge badge--gold">Bestseller</span>
                        <h4>Heritage Collection</h4>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            {% else %}
              <div class="nav-dropdown">
                {% for child_link in link.links %}
                  <a href="{{ child_link.url }}" class="dropdown-link">{{ child_link.title }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% else %}
          <div class="nav-item">
            <a href="{{ link.url }}" class="nav-link {% if link.active %}active{% endif %}">{{ link.title }}</a>
          </div>
        {% endif %}
      {% endfor %}
    </nav>

    <!-- Header Actions -->
    <div class="header-actions">
      <button class="header-icon" onclick="toggleSearch()" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </button>

      <a href="/account" class="header-icon" aria-label="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>

      <button class="header-icon cart-toggle" onclick="openCart()" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {% if cart.item_count > 0 %}
          <span class="cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </button>
    </div>
  </div>

  <!-- Search Bar (slides down) -->
  <div class="search-bar" id="SearchBar">
    <form action="/search" method="get" class="search-form">
      <input type="text" name="q" placeholder="Search sarees, suits, fabrics…" autocomplete="off">
      <button type="submit" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </button>
    </form>
    <button class="search-close" onclick="toggleSearch()">✕</button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div class="mobile-menu" id="MobileMenu">
    <div class="mobile-menu__overlay" onclick="toggleMobileMenu()"></div>
    <div class="mobile-menu__panel">
      <div class="mobile-menu__header">
        <span class="logo-text">{{ section.settings.logo_text }}</span>
        <button onclick="toggleMobileMenu()" aria-label="Close">✕</button>
      </div>
      <nav class="mobile-menu__nav">
        {% for link in linklists[section.settings.main_menu].links %}
          <a href="{{ link.url }}" class="mobile-menu__link">{{ link.title }}</a>
        {% endfor %}
      </nav>
      <div class="mobile-menu__footer">
        <a href="/account">My Account</a>
        <a href="/pages/contact">Contact Us</a>
      </div>
    </div>
  </div>
</header>
