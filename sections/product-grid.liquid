{% schema %}
{
  "name": "Product Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "Products per page",
      "default": 24
    },
    {
      "type": "select",
      "id": "grid_columns",
      "label": "Products per row (desktop)",
      "options": [
        {"value": "3", "label": "3"},
        {"value": "4", "label": "4"}
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filters sidebar",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}

<div class="collection-page">
  <div class="collection-header">
    <div class="container">
      <h1 class="collection-title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="collection-description">{{ collection.description }}</div>
      {% endif %}
      <p class="collection-count">{{ collection.products_count }} products</p>
    </div>
  </div>

  <div class="container">
    <div class="collection-layout {% if section.settings.show_filters %}collection-layout--with-filters{% endif %}">

      <!-- Filter Sidebar -->
      {% if section.settings.show_filters %}
        <aside class="filter-sidebar" id="FilterSidebar">
          <div class="filter-sidebar__header">
            <h3>Filter & Sort</h3>
            <button class="filter-close" onclick="toggleFilters()" aria-label="Close filters">✕</button>
          </div>

          <form id="FacetFiltersForm" class="filter-form">
            {% for filter in collection.filters %}
              <div class="filter-group">
                <button type="button" class="filter-group__toggle" onclick="this.parentElement.classList.toggle('open')">
                  {{ filter.label }}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class="filter-group__options">
                  {% case filter.type %}
                    {% when 'list' %}
                      {% for value in filter.values %}
                        <label class="filter-option">
                          <input
                            type="checkbox"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            {% if value.active %}checked{% endif %}
                            onchange="applyFilters()">
                          <span>{{ value.label }}</span>
                          <span class="filter-count">({{ value.count }})</span>
                        </label>
                      {% endfor %}
                    {% when 'price_range' %}
                      <div class="price-range">
                        <div class="price-range__field">
                          <span>₹</span>
                          <input type="number" placeholder="Min"
                            name="{{ filter.min_value.param_name }}"
                            value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                            onchange="applyFilters()">
                        </div>
                        <span>—</span>
                        <div class="price-range__field">
                          <span>₹</span>
                          <input type="number" placeholder="Max"
                            name="{{ filter.max_value.param_name }}"
                            value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                            onchange="applyFilters()">
                        </div>
                      </div>
                  {% endcase %}
                </div>
              </div>
            {% endfor %}

            <!-- Sort (mobile in sidebar) -->
            <div class="filter-group filter-group--sort">
              <label class="filter-group__toggle">Sort by</label>
              <select name="sort_by" onchange="applySort(this.value)" class="sort-select">
                <option value="manual">Featured</option>
                <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
                <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
                <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest First</option>
                <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
              </select>
            </div>
            
            <div class="filter-sidebar__footer">
              <a href="{{ collection.url }}?sort_by={{ collection.sort_by }}" class="btn btn--outline btn--full">Clear All</a>
            </div>
          </form>
        </aside>
      {% endif %}

      <!-- Product Grid -->
      <div class="products-area">

        <!-- Toolbar -->
        <div class="grid-toolbar">
          {% if section.settings.show_filters %}
            <button class="filter-toggle-btn" onclick="toggleFilters()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
              Filters
              {% assign active_count = 0 %}
              {% for filter in collection.filters %}
                {% assign active_count = active_count | plus: filter.active_values.size %}
              {% endfor %}
              {% if active_count > 0 %}<span class="active-filter-count">{{ active_count }}</span>{% endif %}
            </button>
          {% endif %}

          <!-- Active filter tags -->
          <div class="active-filters">
            {% for filter in collection.filters %}
              {% for value in filter.active_values %}
                <button class="active-filter-tag" onclick="removeFilter('{{ value.param_name }}', '{{ value.value }}')">
                  {{ value.label }} ✕
                </button>
              {% endfor %}
            {% endfor %}
          </div>

          <!-- Sort (desktop) -->
          <select onchange="applySort(this.value)" class="sort-select sort-select--desktop" aria-label="Sort by">
            <option value="manual" {% if collection.sort_by == 'manual' or collection.sort_by == blank %}selected{% endif %}>Sort: Featured</option>
            <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low–High</option>
            <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High–Low</option>
            <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest First</option>
            <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
          </select>
        </div>

        <!-- Grid -->
        <div class="product-grid product-grid--{{ section.settings.grid_columns }}" id="ProductGrid">
          {% paginate collection.products by section.settings.products_per_page %}
            {% for product in collection.products %}
              {% render 'product-card', product: product %}
            {% else %}
              <!-- Premium Placeholder Products for Better Presentation -->
              <div class="empty-collection-container">
                <div class="empty-collection-notice">
                  <h3>Curating Heritage...</h3>
                  <p>Our artisanal collection is currently being refreshed. Discover our featured heritage pieces below.</p>
                </div>
                
                <div class="placeholder-grid">
                  <!-- Dummy 1 -->
                  <div class="product-card" data-animate>
                    <div class="product-card__badges"><span class="badge badge--new">Heritage</span></div>
                    <div class="product-card__media">
                      <img class="product-card__img" src="{{ 'saree_1.png' | asset_url }}" alt="Banarasi Silk Saree" loading="lazy">
                    </div>
                    <div class="product-card__info">
                      <p class="product-card__vendor">Frillve Signature</p>
                      <h3 class="product-card__title">Royal Banarasi Silk Saree</h3>
                      <div class="price-wrapper"><span class="price">₹12,499</span></div>
                    </div>
                  </div>

                  <!-- Dummy 2 -->
                  <div class="product-card" data-animate>
                    <div class="product-card__badges"><span class="badge badge--gold">Bestseller</span></div>
                    <div class="product-card__media">
                      <img class="product-card__img" src="{{ 'saree_2.png' | asset_url }}" alt="Kanjivaram Saree" loading="lazy">
                    </div>
                    <div class="product-card__info">
                      <p class="product-card__vendor">Heritage Collection</p>
                      <h3 class="product-card__title">Emerald Peacock Kanjivaram</h3>
                      <div class="price-wrapper"><span class="price">₹18,200</span></div>
                    </div>
                  </div>

                  <!-- Dummy 3 -->
                  <div class="product-card" data-animate>
                    <div class="product-card__media">
                      <img class="product-card__img" src="{{ 'saree_3.png' | asset_url }}" alt="Chanderi Silk" loading="lazy">
                    </div>
                    <div class="product-card__info">
                      <p class="product-card__vendor">Modern Classics</p>
                      <h3 class="product-card__title">Cream & Gold Chanderi Silk</h3>
                      <div class="price-wrapper"><span class="price">₹8,950</span></div>
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}

            <!-- Pagination -->
            {% if paginate.pages > 1 %}
              <div class="pagination">
                {% if paginate.previous %}
                  <a href="{{ paginate.previous.url }}" class="pagination-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
                    Prev
                  </a>
                {% endif %}
                {% for part in paginate.parts %}
                  {% if part.is_link %}
                    <a href="{{ part.url }}" class="pagination-num">{{ part.title }}</a>
                  {% else %}
                    {% if part.title == paginate.current_page %}
                      <span class="pagination-num pagination-num--active">{{ part.title }}</span>
                    {% else %}
                      <span class="pagination-ellipsis">{{ part.title }}</span>
                    {% endif %}
                  {% endif %}
                {% endfor %}
                {% if paginate.next %}
                  <a href="{{ paginate.next.url }}" class="pagination-btn">
                    Next
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                  </a>
                {% endif %}
              </div>
            {% endif %}
          {% endpaginate %}
        </div>
      </div>
    </div>
  </div>
</div>
