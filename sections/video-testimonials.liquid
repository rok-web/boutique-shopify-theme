{% schema %}
{
  "name": "Video Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Real stories from real people"
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Video Thumbnail"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Video Link (YouTube/Vimeo)",
          "accept": ["youtube", "vimeo"]
        },
        {
          "type": "text",
          "id": "video_file_url",
          "label": "Native Video URL (e.g. Shopify File Link)",
          "info": "Upload a video to Shopify Files and paste the link here for a cleaner look."
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer Name",
          "default": "Happy Parent"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption Overlay",
          "default": "Amazing Quality!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Testimonials",
      "blocks": [
        {"type": "video_card"},
        {"type": "video_card"},
        {"type": "video_card"},
        {"type": "video_card"}
      ]
    }
  ]
}
{% endschema %}

<section class="video-testimonials" id="VideoTestimonials">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{{ section.settings.title }}</h2>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="video-slider-container">
      <div class="video-slider" id="VideoSlider">
        {% for block in section.blocks %}
          {% assign video_src = "" %}
          {% if block.settings.video_file_url != blank %}
            {% assign video_src = block.settings.video_file_url %}
          {% elsif block.settings.video_url != blank %}
            {% if block.settings.video_url.type == 'youtube' %}
              {% assign video_src = "https://www.youtube.com/embed/" | append: block.settings.video_url.id %}
            {% else %}
              {% assign video_src = "https://player.vimeo.com/video/" | append: block.settings.video_url.id %}
            {% endif %}
          {% endif %}

          <div class="video-card" {{ block.shopify_attributes }} onclick="openVideoPlayer('{{ video_src }}')">
            <div class="video-card__top-text">
              Real Frillve <span class="highlight">Success Story</span>
            </div>
            <div class="video-card__media">
              {% if block.settings.thumbnail %}
                <img src="{{ block.settings.thumbnail | image_url: width: 400 }}" alt="{{ block.settings.customer_name }}" loading="lazy">
              {% else %}
                {% assign thumb_index = forloop.index | modulo: 2 | plus: 1 %}
                {% assign thumb_name = 'video_thumb_' | append: thumb_index | append: '.png' %}
                <img src="{{ thumb_name | asset_url }}" alt="Review Thumbnail" loading="lazy">
              {% endif %}
              
              <div class="video-card__overlay">
                <div class="video-play-btn">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                </div>
                {% if block.settings.caption != blank %}
                  <div class="video-card__caption">{{ block.settings.caption }}</div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      
      <div class="slider-controls">
        <button class="slider-arrow prev" onclick="scrollVideoSlider(-1)" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="slider-arrow next" onclick="scrollVideoSlider(1)" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Video Player Modal -->
  <div id="VideoPlayerModal" class="video-modal" onclick="closeVideoPlayer()">
    <div class="video-modal__content" onclick="event.stopPropagation()">
      <button class="video-modal__close" onclick="closeVideoPlayer()">&times;</button>
      <div class="video-modal__container" id="VideoContainer">
        <!-- Video iframe or video tag inserted here -->
      </div>
    </div>
  </div>
</section>

<script>
function scrollVideoSlider(direction) {
  const slider = document.getElementById('VideoSlider');
  const scrollAmount = slider.offsetWidth * 0.8;
  slider.scrollBy({
    left: direction * scrollAmount,
    behavior: 'smooth'
  });
}

function openVideoPlayer(src) {
  if (!src) {
    showToast('Demo video: Functionality active. Please add a video link in theme settings.', 'info');
    return;
  }
  
  const modal = document.getElementById('VideoPlayerModal');
  const container = document.getElementById('VideoContainer');
  
  if (src.includes('youtube.com') || src.includes('vimeo.com')) {
    container.innerHTML = `<iframe src="${src}?autoplay=1" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>`;
  } else {
    container.innerHTML = `<video src="${src}" controls autoplay style="width:100%; height:100%;"></video>`;
  }
  
  modal.classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeVideoPlayer() {
  const modal = document.getElementById('VideoPlayerModal');
  const container = document.getElementById('VideoContainer');
  modal.classList.remove('active');
  container.innerHTML = '';
  document.body.style.overflow = '';
}
</script>

<style>
.video-testimonials {
  padding: 80px 0;
  background: var(--clr-white);
}

.video-slider-container {
  position: relative;
  margin-top: 40px;
}

.video-slider {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding: 0 20px 20px;
}

.video-slider::-webkit-scrollbar {
  display: none;
}

.video-card {
  flex: 0 0 280px;
  scroll-snap-align: start;
  border-radius: 24px;
  overflow: hidden;
  background: var(--clr-emerald);
  padding: 12px; /* Thick emerald frame */
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  display: flex;
  flex-direction: column;
  gap: 10px;
  box-shadow: 0 10px 30px rgba(6, 78, 59, 0.15);
}

.video-card:hover {
  transform: translateY(-8px) scale(1.02);
  box-shadow: 0 20px 40px rgba(6, 78, 59, 0.25);
}

.video-card__top-text {
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  text-align: center;
  line-height: 1.3;
  padding: 4px 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.video-card__top-text .highlight {
  color: #FFD700; /* Gold highlight like screenshot */
}

.video-card__media {
  position: relative;
  aspect-ratio: 9/14; /* Adjusted for the frame */
  border-radius: 16px;
  overflow: hidden;
  background: #000;
}

.video-card__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.video-card:hover .video-card__media img {
  transform: scale(1.1);
}

.video-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0) 50%, rgba(0,0,0,0.7) 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.video-play-btn {
  width: 54px;
  height: 54px;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  border: 1px solid rgba(255,255,255,0.4);
  transition: all 0.3s ease;
}

.video-card:hover .video-play-btn {
  background: var(--clr-gold);
  border-color: var(--clr-gold);
  color: var(--clr-maroon);
  transform: scale(1.15);
}

.video-card__caption {
  position: absolute;
  bottom: 15px;
  left: 15px;
  right: 15px;
  color: #fff;
  font-size: 0.85rem;
  font-weight: 600;
  text-align: center;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

/* Video Modal */
.video-modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.9);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.video-modal.active {
  opacity: 1;
  visibility: visible;
}

.video-modal__content {
  width: 90%;
  max-width: 450px;
  aspect-ratio: 9/16;
  position: relative;
}

.video-modal__container {
  width: 100%;
  height: 100%;
  border-radius: 12px;
  overflow: hidden;
  background: #000;
}

.video-modal__container iframe {
  width: 100%;
  height: 100%;
}

.video-modal__close {
  position: absolute;
  top: -40px;
  right: 0;
  background: none;
  border: none;
  color: #fff;
  font-size: 2.5rem;
  cursor: pointer;
}

@media (max-width: 768px) {
  .video-card { flex: 0 0 220px; }
}
</style>

