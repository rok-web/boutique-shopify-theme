<div id="QuickViewModal" class="modal-overlay quick-view-modal" style="display: none;" onclick="if(event.target === this) closeQuickView()">
  <div class="modal-content quick-view-content">
    <button class="modal-close" onclick="closeQuickView()">&times;</button>
    <div class="quick-view-grid">
      <div class="quick-view-media">
        <div class="quick-view-img-wrapper">
          <img id="QVMainImg" src="" alt="Product Image" loading="lazy">
        </div>
      </div>
      <div class="quick-view-info">
        <h2 id="QVTitle" class="quick-view-title"></h2>
        <div class="quick-view-price-wrapper">
          <span id="QVPrice" class="quick-view-price"></span>
          <span id="QVComparePrice" class="quick-view-compare-price" style="display: none;"></span>
        </div>
        <p id="QVDescription" class="quick-view-desc"></p>
        
        <form id="QVForm" class="quick-view-form">
          <input type="hidden" name="id" id="QVVariantId" value="">
          <div id="QVOptions" class="quick-view-options"></div>
          
          <div class="quick-view-actions">
            <div class="qty-selector">
              <button type="button" onclick="this.nextElementSibling.value = Math.max(1, parseInt(this.nextElementSibling.value) - 1)">−</button>
              <input type="number" name="quantity" value="1" min="1">
              <button type="button" onclick="this.previousElementSibling.value = parseInt(this.previousElementSibling.value) + 1">+</button>
            </div>
            <button type="submit" class="btn btn--primary btn--full qv-atc-btn">Add to Bag</button>
          </div>
        </form>
        
        <a id="QVFullDetails" href="" class="quick-view-link">View Full Details →</a>
      </div>
    </div>
  </div>
</div>

<style>
.quick-view-modal {
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.quick-view-content {
  max-width: 900px;
  width: 95%;
  padding: 0;
  overflow: hidden;
  border-radius: var(--radius-lg);
}
.quick-view-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.quick-view-media {
  background: #f9f9f9;
}
.quick-view-img-wrapper {
  aspect-ratio: 4/5;
  overflow: hidden;
}
.quick-view-img-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.quick-view-info {
  padding: 40px;
  display: flex;
  flex-direction: column;
}
.quick-view-title {
  font-family: var(--font-display);
  font-size: 1.8rem;
  margin-bottom: 10px;
}
.quick-view-price-wrapper {
  margin-bottom: 20px;
}
.quick-view-price {
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--clr-maroon);
}
.quick-view-compare-price {
  font-size: 1rem;
  text-decoration: line-through;
  color: #999;
  margin-left: 10px;
}
.quick-view-desc {
  font-size: 0.9rem;
  color: #666;
  margin-bottom: 25px;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.quick-view-options {
  margin-bottom: 20px;
}
.quick-view-actions {
  display: flex;
  gap: 15px;
  margin-bottom: 20px;
}
.quick-view-link {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--clr-ink-muted);
  text-decoration: underline;
  margin-top: auto;
}

@media (max-width: 768px) {
  .quick-view-grid {
    grid-template-columns: 1fr;
    max-height: 80vh;
    overflow-y: auto;
  }
  .quick-view-info {
    padding: 25px;
  }
}
</style>
