<div id="StickyATC" class="sticky-atc">
  <div class="sticky-atc__container">
    <div class="sticky-atc__info">
      <img src="{{ product.featured_image | image_url: width: 60 }}" alt="{{ product.title }}">
      <div class="sticky-atc__text">
        <p class="sticky-atc__title">{{ product.title }}</p>
        <p class="sticky-atc__price">{{ product.price | money }}</p>
      </div>
    </div>
    <button class="btn btn--primary btn--full atc-btn" onclick="document.querySelector('.product-atc form .atc-btn').click()">
      Add to Bag
    </button>
  </div>
</div>

<style>
.sticky-atc {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  padding: 12px 16px;
  border-top: 1px solid var(--clr-border);
  z-index: 800;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  display: none; /* Controlled by JS and Media Query */
}

.sticky-atc.visible {
  transform: translateY(0);
}

.sticky-atc__container {
  display: flex;
  align-items: center;
  gap: 15px;
  max-width: 600px;
  margin: 0 auto;
}

.sticky-atc__info {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  min-width: 0;
}

.sticky-atc__info img {
  width: 40px;
  height: 40px;
  object-fit: cover;
  border-radius: var(--radius-sm);
}

.sticky-atc__text {
  min-width: 0;
}

.sticky-atc__title {
  font-size: 0.85rem;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin: 0;
}

.sticky-atc__price {
  font-size: 0.8rem;
  color: var(--clr-maroon);
  font-weight: 600;
  margin: 0;
}

@media (max-width: 768px) {
  .sticky-atc {
    display: block;
    padding-bottom: env(safe-area-inset-bottom, 12px);
  }
}
</style>
